# Get your API key at https://openrouter.ai/ 
# This app uses paid LLMs (<$1 expenditure), your OpenRouter account needs credits.
OPENROUTER_API_KEY=your_key_here

# Get your free API key at https://app.tavily.com/ 
TAVILY_API_KEY=your_key_here

# Web Search (Tavily) Configuration
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=4

# LLM Configuration
LLM_TIMEOUT=60

# Feature Flags
# Set to 1 to enable web search tool (using Tavily), 0 to disable
ENABLE_LLM_TOOLS=1
WEB_TIMEOUT=20

# Centralized Database Contribution (Vercel Proxy)
# DO NOT MODIFY
CONTRIBUTION_PROXY_URL=your_proxy_url_here


# Processing Limits (optional, each script has custom default values)
# MAX_PDF_PAGES=int
# MAX_PDF_CHARS=int
# MAX_OUTPUT_TOKENS=int




